generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ServiceStatus {
  ORCAMENTO
  AGUARDANDO_RECEITA
  PRONTO_ENTREGA
  FINALIZADO
}

model Patient {
  id               String    @id @default(uuid())
  name             String
  phone            String
  lastPurchaseDate DateTime?
  lgpdConsent      Boolean   @default(false)
  services         Service[]
  
  // Histórico médico sensível
  medicalHistory   String?   /// @encrypted

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Product {
  id                String           @id @default(uuid())
  activeIngredient  String
  stockQuantity     Int
  expirationDate    DateTime
  costPrice         Decimal          @db.Decimal(10, 2)
  salePrice         Decimal          @db.Decimal(10, 2)
  accumulatedProfit Decimal          @default(0) @db.Decimal(10, 2)
  abcClass          String           @db.Char(1)

  services          ServiceProduct[]

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model Service {
  id                    String           @id @default(uuid())
  patientId             String
  patient               Patient          @relation(fields: [patientId], references: [id])
  status                ServiceStatus    @default(ORCAMENTO)
  prescriptionValidated Boolean          @default(false)
  
  // Relacionamento N:M com produtos e suas quantidades
  products              ServiceProduct[]

  // Receitas ou laudos médicos
  prescriptionData      String?          /// @encrypted

  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
}

model ServiceProduct {
  id        String   @id @default(uuid())
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([serviceId, productId])
}

model AuditLog {
  id           String   @id @default(uuid())
  userId       String
  action       String
  dataAccessed String
  timestamp    DateTime @default(now())
}
